# FlexEdgeAdmin — Environment Variables
# Copy to .env at project root and fill in real values.
# DO NOT commit .env to git.

# ── Flask ─────────────────────────────────────────────────────────────────
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=REPLACE_WITH_64_HEX_CHARS
FLASK_DEBUG=0
PORT=5000

# ── Microsoft Entra ID (Azure AD) ────────────────────────────────────────
# Create an App Registration in Entra ID portal and fill these in.
# Redirect URI: https://your-domain/auth/callback
AZURE_TENANT_ID=REPLACE_WITH_TENANT_UUID
AZURE_CLIENT_ID=REPLACE_WITH_CLIENT_ID
AZURE_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET

# ── Database ─────────────────────────────────────────────────────────────
# SQLite database and encryption key (auto-generated on first run)
DATABASE_URL=sqlite:////config/flexedge.db
ENCRYPTION_KEY_FILE=/config/encryption.key

# ── Legacy config paths (only needed during JSON migration) ──────────────
# USERS_CONFIG=/config/users.json
# TENANTS_CONFIG=/config/tenants.json

# ── CLI usage (for docker exec CLI commands) ──────────────────────────────
SMC_API_KEY=REPLACE_WITH_CLI_API_KEY
DEFAULT_TENANT=prod

# ── App branding (optional) ──────────────────────────────────────────────
APP_TITLE=FlexEdgeAdmin

# ── TLS / Production (only needed for docker-compose.prod.yml) ───────────
DOMAIN=admin.yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com
